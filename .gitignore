# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# Yarn Berry (https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
# !.yarn/cache  # uncomment for zero-installs

.yarn/install-state.gz
.yarn/build-state.yml
.yarn/unplugged

# Yarn PnP
.pnp.*
/.pnp

# other package managers
package-lock.json
npm-shrinkwrap.json
.yarn-integrity

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local database
/data/*.db

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
